{
	"compilerOptions": {
		"lib": [
			"ESNext",
			"DOM",
			"DOM.Iterable"
		],
		"rootDir": "src",
		"outDir": "out",
		"inlineSourceMap": true,
		"strict": false,
		"allowJs": false,
		"checkJs": false,
		"noEmitOnError": true,
		"forceConsistentCasingInFileNames": true,
		"target": "esnext"
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.d.ts"
	],
	"exclude": [
		"out/**/*"
	]
}
